# ============================================================================
# VidaSUS - Variáveis de Ambiente
# ============================================================================
# 🔐 SEGURANÇA: Nunca comite o arquivo .env com valores reais!
# Use este arquivo como template: cp .env.example .env
# O arquivo .env está no .gitignore e não será enviado ao repositório
# ============================================================================

# OpenAI API Key (para chat com IA)
# Obtenha em: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-your-key-here

# ============================================================================
# INTEGRAÇÕES COM APIs DO SUS (para MVP/produção futura)
# ============================================================================

# RNDS - Rede Nacional de Dados em Saúde
# Documentação: https://rnds.saude.gov.br
# Nota: Requer credenciamento formal como estabelecimento de saúde
# Status: Roadmap para integração futura
# RNDS_CLIENT_ID=seu-client-id-aqui
# RNDS_CLIENT_SECRET=seu-client-secret-aqui

# CNES - Cadastro Nacional de Estabelecimentos de Saúde  
# API Pública: https://apidadosabertos.saude.gov.br
# Status: Possível integração em beta
# CNES_API_KEY=sua-api-key-aqui

# ============================================================================
# MVP ATUAL: Todos os dados de histórico médico são mockados
# Nenhuma integração com API do SUS é necessária no momento
# ============================================================================

